# Token Trail - Environment Variables
# Copy this file to .env and adjust values for your environment.
# Usage: cp .env.example .env (Linux/Mac) or Copy-Item .env.example .env (Windows)

# MongoDB (inside Docker Compose)
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=token_trail

# If you run backend OUTSIDE Docker use:
# MONGO_URI=mongodb://localhost:27017

# JWT Backend / Auth
JWT_SECRET=change-me
JWT_EXPIRES_MINUTES=60

# File uploads
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=50

# Assignment lifecycle
DEFAULT_RETENTION_DAYS=30

# Privacy/anonymization
ANONYMIZATION_MODE=none
ANONYMIZATION_SALT=

# Notification/email
EMAIL_PROVIDER=none
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=1

# Rate-limit controls (0 = disabled)
RATE_LIMIT_AUTH_ATTEMPTS_PER_HOUR=0
RATE_LIMIT_SUBMISSION_ATTEMPTS_PER_HOUR=0

# CORS (frontend dev origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
